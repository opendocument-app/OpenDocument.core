[settings]
arch=x86_64
build_type=Release
compiler=gcc
compiler.version=14
compiler.cppstd=20
compiler.libcxx=libstdc++11
os=Linux

[conf]
tools.build:compiler_executables={'c': 'gcc-14', 'cpp': 'g++-14'}
tools.cmake.cmaketoolchain:extra_variables={'CMAKE_CXX_COMPILER_LAUNCHER': 'ccache', 'CMAKE_C_COMPILER_LAUNCHER': 'ccache'}

[buildenv]
CC=ccache g++-14
CXX=ccache g++-14
